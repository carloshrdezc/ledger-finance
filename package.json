{
  "name": "ledger-finance",
  "version": "1.0.0",
  "description": "LEDGER — Personal Finance App",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.ledger.finance",
    "productName": "LEDGER",
    "directories": { "output": "dist-app" },
    "files": ["dist/**/*", "src/main/**/*"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.13",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
